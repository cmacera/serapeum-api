{
  "name": "@serapeum/shared-schemas",
  "version": "1.0.0",
  "description": "Shared Zod schemas and TypeScript types for the Serapeum API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "zod": "^3.24.1"
  }
}
