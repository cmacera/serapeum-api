# Environment Configuration for Serapeum API

# Server Configuration
PORT=3000
GENKIT_ENV=dev

# AI Configuration
# Options: 'google', 'ollama', 'ollama-cloud', 'openrouter'
AI_PROVIDER=google

# --- Google AI ---
GOOGLE_GENAI_API_KEY=your_google_genai_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# --- Ollama ---
OLLAMA_MODEL=qwen3:14b
OLLAMA_SERVER_URL=http://localhost:11434

# --- Ollama Cloud (production) ---
OLLAMA_CLOUD_API_KEY=your_ollama_cloud_api_key_here
OLLAMA_CLOUD_MODEL=gpt-oss:120b-cloud

# --- OpenRouter ---
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=anthropic/claude-3-haiku

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:*,https://editor.genkit.ai

# TMDB Configuration
TMDB_API_KEY=your_tmdb_api_key_here

# Google Books Configuration
GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here

# IGDB Configuration
IGDB_CLIENT_ID=your_igdb_client_id_here
IGDB_CLIENT_SECRET=your_igdb_client_secret_here

# Tavily Configuration
TAVILY_API_KEY=your_tavily_api_key_here

# Supabase Configuration (when needed)
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_URL=your_supabase_url

# Langfuse Telemetry (optional — production observability)
# Sign up at https://cloud.langfuse.com
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# Debug Configuration
# Set to 'true' to enable verbose debug logging (e.g. AI provider/model on startup)
DEBUG=false

# Testing Configuration
# Set to 'true' to run E2E tests locally (HITS REAL APIs)
RUN_E2E=false
