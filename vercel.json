{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["fra1"],
  "outputDirectory": "dist",
  "git": {
    "deploymentEnabled": {
      "main": false
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index" }],
  "functions": {
    "api/index.ts": {
      "maxDuration": 300,
      "includeFiles": "{prompts,src/locales}/**"
    }
  },
  "crons": [
    {
      "path": "/health",
      "schedule": "0 9 */5 * *"
    }
  ]
}
