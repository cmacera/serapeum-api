{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["fra1"],
  "outputDirectory": "dist",
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index" }],
  "functions": {
    "api/index.ts": {
      "maxDuration": 300,
      "includeFiles": "{prompts,src/locales}/**"
    }
  }
}
